DB_HOST=localhost
DB_PORT=5432
DB_NAME=oilgas
DB_USER=postgres
DB_PASSWORD=

# Enverus
ENVERUS_SECRET_KEY=

# Novi
NOVI_EMAIL=
NOVI_PASSWORD=
NOVI_SCOPE=us-horizontals
NOVI_VERSION=v3

# Novi INTEL Snowflake share (reader account; etl/intel_sf)
# Account identifier from Novi's onboarding email, e.g. novilabs-<org>
# (the part before .snowflakecomputing.com). PAT = programmatic access token.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PAT=
# Defaults below match Novi's reader-account provisioning; override only if
# Novi says otherwise (all optional — code defaults to these values).
SNOWFLAKE_ROLE=DATA_READER
SNOWFLAKE_WAREHOUSE=NOVI_WH
SNOWFLAKE_DATABASE=NOVI_DATA_ACCESS
SNOWFLAKE_SCHEMA=NOVI_INTEL

# --- Daily run notifications ---
# All optional; missing values disable that channel cleanly.
#
# Email summary at end of every run_daily (success or failure). Gmail
# requires an APP PASSWORD here (not the account password):
#   https://myaccount.google.com/apppasswords  (needs 2FA enabled first)
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587
NOTIFY_SMTP_USER=
NOTIFY_SMTP_PASS=
#
# healthchecks.io dead-man's-switch. Catches the case where the
# scheduled task never fires at all (laptop asleep, user not logged in,
# Task Scheduler silently dying) — email can't detect that on its own.
# Sign up free at https://healthchecks.io, create a daily-at-06:00
# check with a ~2h grace window, paste its ping URL here.
HEALTHCHECKS_PING_URL=
